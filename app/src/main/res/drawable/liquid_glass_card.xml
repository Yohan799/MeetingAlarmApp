<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer soft glow shadow -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D4B7BF5" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    
    <!-- Main glass background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A1E" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    
    <!-- Gradient border overlay -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1.5dp" android:color="#404B7BF5" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    
    <!-- Inner highlight for depth -->
    <item android:bottom="1dp" android:left="1dp" android:right="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#15FFFFFF" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
