<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <layer-list>
            <!-- Soft glow beneath button -->
            <item android:bottom="-4dp" android:left="8dp" android:right="8dp" android:top="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#304B7BF5" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <!-- Gradient fill -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#4B7BF5"
                        android:centerColor="#5B8AF5"
                        android:endColor="#3A62C4" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>
