<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- Obsidian Cosmos - Premium Design System Tokens                       -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Core Backgrounds -->
    <color name="bg_void">#080810</color>           <!-- True deep background -->
    <color name="bg_surface">#0F0F18</color>        <!-- Elevated cards level 1 -->
    <color name="bg_raised">#161625</color>         <!-- Dialogs, sheets level 2 -->

    <!-- Glassmorphism -->
    <color name="glass_fill">#0DFFFFFF</color>      <!-- ~3.1% white (approx 0D hex) -->
    <color name="glass_border">#14FFFFFF</color>    <!-- 8% white border -->
    <color name="glass_border_highlight">#33FFFFFF</color>
    
    <!-- Primary Brand Colors -->
    <color name="primary_vivid">#5B8AF8</color>     <!-- Electric Blue -->
    <color name="primary_glow">#405B8AF8</color>    <!-- 25% Opacity -->
    <color name="primary_deep">#1E3A7A</color>      <!-- Shadow/Deep tone -->

    <!-- Secondary/Accent Colors -->
    <color name="teal_core">#2FF4DC</color>         <!-- Luminous Teal -->
    <color name="teal_glow">#302FF4DC</color>       <!-- Ambient glow -->
    <color name="teal_muted">#1A8A7E</color>        <!-- Darker surfaces -->

    <!-- Semantic Colors -->
    <color name="amber_pulse">#FBBF24</color>       <!-- Alarm states, urgency -->
    <color name="amber_glow">#30FBBF24</color>
    <color name="emerald_action">#22D3A8</color>    <!-- Join button -->
    <color name="emerald_glow">#2522D3A8</color>
    <color name="danger_core">#FF5E5E</color>       <!-- Critical alerts -->

    <!-- Text Colors -->
    <color name="text_primary">#F2F2FF</color>      <!-- Near-white, cool cast -->
    <color name="text_secondary">#8B95B0</color>    <!-- Cool slate -->
    <color name="text_tertiary">#4A5270</color>     <!-- Ghost text -->
    <color name="text_inverse">#0A0A14</color>      <!-- Dark text on light buttons -->
    <color name="text_teal">#2FF4DC</color>         <!-- Teal text -->

    <!-- Utility -->
    <color name="divider">#0DFFFFFF</color>         <!-- 5% white -->
    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>
    <color name="transparent">#00000000</color>

    <!-- Gradient Tokens -->
    <color name="gradient_start">#2FF4DC</color>    <!-- Teal -->
    <color name="gradient_mid">#5B8AF8</color>      <!-- Electric Blue -->
    <color name="gradient_end">#3A5FD0</color>      <!-- Deep Cobalt -->

    <!-- Legacy Mappings (to prevent build errors during migration) -->
    <color name="primary">@color/primary_vivid</color>
    <color name="primary_dark">@color/primary_deep</color>
    <color name="accent">@color/amber_pulse</color>
    <color name="background_primary">@color/bg_void</color>
    <color name="surface">@color/bg_surface</color>

    <!-- Drawable-referenced colors (mapped to design system tokens) -->
    <color name="alarm_active">@color/amber_pulse</color>
    <color name="surface_light">@color/bg_raised</color>
    <color name="card_border">@color/glass_border</color>
    <color name="card_background">@color/bg_surface</color>
    <color name="gradient_middle">@color/gradient_mid</color>
</resources>
