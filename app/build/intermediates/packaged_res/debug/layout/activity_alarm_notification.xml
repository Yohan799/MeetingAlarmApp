<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_obsidian_gradient">

    <!-- Ambient Glow Orb - Top Right -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:alpha="0.2"
        android:background="@drawable/bg_glow_orb"
        android:backgroundTint="@color/teal_core"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ambient Glow Orb - Bottom Left -->
    <View
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginStart="-80dp"
        android:layout_marginBottom="-40dp"
        android:alpha="0.15"
        android:background="@drawable/bg_glow_orb"
        android:backgroundTint="@color/primary_vivid"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Main Pulsing Background with Glow -->
    <FrameLayout
        android:id="@+id/pulseContainer"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:layout_constraintBottom_toTopOf="@+id/contentCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <!-- Pulse Ring 3 (Outer) -->
        <View
            android:id="@+id/pulseRing3"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:alpha="0.1"
            android:background="@drawable/ic_pulse_ring"
            android:backgroundTint="@color/primary_vivid" />

        <!-- Pulse Ring 2 -->
        <View
            android:id="@+id/pulseRing2"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:alpha="0.2"
            android:background="@drawable/ic_pulse_ring"
            android:backgroundTint="@color/primary_vivid" />

        <!-- Pulse Ring 1 (Inner) -->
        <View
            android:id="@+id/pulseRing1"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:alpha="0.3"
            android:background="@drawable/ic_pulse_ring"
            android:backgroundTint="@color/primary_vivid" />

        <!-- Alarm Icon -->
        <ImageView
            android:id="@+id/ivAlarmIcon"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:src="@drawable/ic_alarm_logo"
            app:tint="@color/white" />

    </FrameLayout>

    <!-- Content Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_glass_card"
        android:padding="32dp"
        app:layout_constraintBottom_toTopOf="@+id/buttonContainer"
        app:layout_constraintTop_toBottomOf="@+id/pulseContainer"
        app:layout_constraintVertical_bias="0.2"
        tools:layout_editor_absoluteX="24dp">

        <TextView
            android:id="@+id/tvAlarmTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:text="MEETING STARTING"
            android:textColor="@color/teal_core"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.01"
            android:text="Team Standup"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvAlarmTitle" />

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_gradient_button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvEventTitle" />

        <TextView
            android:id="@+id/tvEventTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-light"
            android:text="10:30 AM"
            android:textColor="@color/text_primary"
            android:textSize="56sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <TextView
            android:id="@+id/tvEventDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.6"
            android:fontFamily="sans-serif"
            android:text="Today"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvEventTime" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Action Buttons Container -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="48dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Join Meeting Button (Primary) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnJoinMeeting"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_gradient_button"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03"
            android:text="Join Meeting Now"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Snooze and Dismiss Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSnooze"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_glass_card"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02"
                android:text="Snooze"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDismiss"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_glass_card"
                android:fontFamily="sans-serif-medium"
                android:text="Dismiss"
                android:textAllCaps="false"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />

        </LinearLayout>
        
        <TextView
            android:id="@+id/tvMeetingLink"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="0dp"
            android:visibility="gone"
            tools:visibility="gone"
             />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
