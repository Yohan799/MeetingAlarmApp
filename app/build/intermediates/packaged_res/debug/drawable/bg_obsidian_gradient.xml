<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="@color/bg_void"
        android:centerColor="@color/bg_void"
        android:endColor="@color/primary_deep"
        android:type="linear" />
    <!-- Note: Complex gradients with multiple stops are limited in XML.
         We simulate the "Teal -> Blue -> Deep Cobalt" wash via code or a separate overlay.
         For the base background, we want a deep void that fades slightly to blue at the bottom-right.
    -->
</shape>
