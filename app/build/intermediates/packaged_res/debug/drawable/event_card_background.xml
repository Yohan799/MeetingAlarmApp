<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#08000000" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Main background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1E" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    
    <!-- Gradient accent bar on left -->
    <item android:right="0dp" android:left="0dp" android:top="0dp" android:bottom="0dp">
        <clip android:clipOrientation="horizontal" android:gravity="left">
            <shape android:shape="rectangle">
                <gradient
                    android:type="linear"
                    android:angle="270"
                    android:startColor="#4B7BF5"
                    android:endColor="#2DD4BF" />
                <corners android:topLeftRadius="20dp" android:bottomLeftRadius="20dp" 
                    android:topRightRadius="0dp" android:bottomRightRadius="0dp" />
                <size android:width="4dp" />
            </shape>
        </clip>
    </item>
    
    <!-- Subtle border -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#252529" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
