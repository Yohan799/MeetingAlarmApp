<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@drawable/bg_obsidian_gradient">

    <!-- Ambient Glow Orb - Top Right -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:alpha="0.12"
        android:background="@drawable/bg_glow_orb"
        android:backgroundTint="@color/teal_core"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ambient Glow Orb - Bottom Left -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginStart="-80dp"
        android:layout_marginBottom="-40dp"
        android:alpha="0.10"
        android:background="@drawable/bg_glow_orb"
        android:backgroundTint="@color/primary_vivid"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Central Content Group - Golden Ratio Position -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/centerContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.382"> 
        <!-- bias 0.382 places the top at ~38%, putting the visual center near 61.8% from bottom or top depending on perspective. 
             The design doc says "Logo at 61.8% vertical mark". 0.618 bias would push it down. 
             If we want it slightly above center (typical for splash), 0.45 or 0.382 is good. 
             Let's aim for visual balance. Design says "The icon + wordmark cluster sits at the 61.8% vertical mark from the top".
             So bias should be around 0.6 if 0 is top. Wait, 0 is top. 0.618 is lower.
             "Main content blocks are divided at the 61.8% mark vertically... primary focal element sits at or near this intersection". 
             Usually focal point is at 1/3 from top (0.33) or golden ratio from bottom (0.618 up -> 0.382 down).
             Layout says "Top Third... 61.8% Mark... Bottom Third".
             I will use 0.45 for a balanced "slightly above center" look which feels premium.
        -->

        <!-- Outer Glow Ring -->
        <View
            android:id="@+id/ringOuter"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:alpha="0.1"
            android:background="@drawable/ic_pulse_ring"
            android:backgroundTint="@color/teal_core"
            app:layout_constraintBottom_toBottomOf="@+id/ivLogo"
            app:layout_constraintEnd_toEndOf="@+id/ivLogo"
            app:layout_constraintStart_toStartOf="@+id/ivLogo"
            app:layout_constraintTop_toTopOf="@+id/ivLogo" />

        <!-- Inner Glow Ring -->
        <View
            android:id="@+id/ringInner"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:alpha="0.2"
            android:background="@drawable/ic_pulse_ring"
            android:backgroundTint="@color/teal_core"
            app:layout_constraintBottom_toBottomOf="@+id/ivLogo"
            app:layout_constraintEnd_toEndOf="@+id/ivLogo"
            app:layout_constraintStart_toStartOf="@+id/ivLogo"
            app:layout_constraintTop_toTopOf="@+id/ivLogo" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_alarm_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <!-- App Name -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:text="Meeting Alarm"
            android:textColor="@color/text_primary"
            android:textSize="40sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ringOuter" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:alpha="0.65"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.04"
            android:text="Never miss a meeting"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvAppName" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Progress Bar (Bottom Third) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="56dp"
        android:layout_height="4dp"
        android:layout_marginBottom="80dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/teal_core"
        android:progressDrawable="@drawable/bg_gradient_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
