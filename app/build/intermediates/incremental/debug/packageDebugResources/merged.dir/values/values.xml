    <style name="ObsidianButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="ObsidianButton.Glass" parent="ObsidianButton">
        <item name="backgroundTint">@color/glass_fill</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="ObsidianButton.Primary" parent="ObsidianButton">
        <item name="background">@drawable/bg_gradient_button</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="ObsidianButton.Secondary" parent="ObsidianButton">
        <item name="backgroundTint">@color/bg_raised</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/teal_core</item>
    </style>
    <style name="ObsidianCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_fill</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="Theme.MeetingAlarm" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/primary_vivid</item>
        <item name="colorPrimaryDark">@color/primary_deep</item>
        <item name="colorAccent">@color/amber_pulse</item>
        
        
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_void</item>
        
        
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        
        <item name="android:fontFamily">sans-serif</item> 
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        
        <item name="colorControlHighlight">@color/primary_glow</item>
    </style>
    <style name="Theme.MeetingAlarm.AlarmScreen" parent="Theme.MeetingAlarm">
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:statusBarColor">@color/bg_void</item>
        <item name="android:navigationBarColor">@color/bg_void</item>
        <item name="android:windowShowWallpaper">false</item>
    </style>
    <style name="Theme.MeetingAlarm.Splash" parent="Theme.MeetingAlarm">
        <item name="android:windowBackground">@drawable/bg_obsidian_gradient</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/gradient_end</item>
    </style>
</resources>