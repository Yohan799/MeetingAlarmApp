<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <!-- Card Background -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/chipStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Design System Review" />

        <!-- Time -->
        <TextView
            android:id="@+id/tvEventTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.75"
            android:fontFamily="sans-serif"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvEventTitle"
            tools:text="10:00 AM - 11:30 AM" />

        <!-- Status Chip (Glass Pill) -->
        <TextView
            android:id="@+id/chipStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_pill"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textColor="@color/teal_core"
            android:textSize="12sp"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Active" />

        <!-- Divider Line -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_shimmer_line"
            android:alpha="0.2"
            app:layout_constraintTop_toBottomOf="@+id/tvEventTime" />

        <!-- Actions Container -->
        <LinearLayout
            android:id="@+id/actionsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/divider">

            <!-- Cancel Button -->
            <TextView
                android:id="@+id/btnCancelAlarm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:fontFamily="sans-serif-medium"
                android:padding="8dp"
                android:text="Turn Off"
                android:textColor="@color/text_tertiary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- View Notes Button (Fathom) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnViewNotes"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_glass_pill"
                android:drawableStart="@drawable/ic_join_meeting"
                android:drawablePadding="6dp"
                android:drawableTint="@color/teal_core"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="12dp"
                android:text="Notes"
                android:textAllCaps="false"
                android:textColor="@color/teal_core"
                android:textSize="13sp"
                android:visibility="gone"
                android:stateListAnimator="@null"
                tools:visibility="visible" />

            <!-- Join Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnJoinMeeting"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_glass_pill"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="16dp"
                android:text="Join"
                android:textAllCaps="false"
                android:textColor="@color/teal_core"
                android:textSize="14sp"
                android:visibility="gone"
                android:stateListAnimator="@null"
                tools:visibility="visible" />

            <!-- Set Alarm Button (Primary) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSetAlarm"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_gradient_button"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="24dp"
                android:text="Set Alarm"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="visible"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
